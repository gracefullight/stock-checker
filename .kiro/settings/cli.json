{
  "chat.defaultAgent": "oma-hooks",
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--isolated"
      ]
    },
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        ".",
        "--open-web-dashboard",
        "false"
      ]
    }
  },
  "hooks": {
    "userPromptSubmit": [
      {
        "hooks": [
          {
            "name": "oma-hook-userPromptSubmit",
            "type": "command",
            "command": "'.kiro/hooks/oma-hook.sh' --vendor 'kiro' --event 'userPromptSubmit'",
            "timeout": 21
          }
        ]
      }
    ],
    "preToolUse": [
      {
        "hooks": [
          {
            "name": "oma-hook-preToolUse",
            "type": "command",
            "command": "'.kiro/hooks/oma-hook.sh' --vendor 'kiro' --event 'preToolUse' --matcher 'shell'",
            "timeout": 10
          }
        ],
        "matcher": "shell"
      }
    ],
    "stop": [
      {
        "hooks": [
          {
            "name": "oma-hook-stop",
            "type": "command",
            "command": "'.kiro/hooks/oma-hook.sh' --vendor 'kiro' --event 'stop'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
