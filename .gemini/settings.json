{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "name": "oma-hook-BeforeAgent",
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR/.gemini/hooks/oma-hook.sh\" --vendor 'gemini' --event 'BeforeAgent' --matcher '*'",
            "timeout": 16005
          }
        ],
        "matcher": "*"
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "name": "oma-hook-BeforeTool",
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR/.gemini/hooks/oma-hook.sh\" --vendor 'gemini' --event 'BeforeTool' --matcher 'run_shell_command'",
            "timeout": 5005
          }
        ],
        "matcher": "run_shell_command"
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "name": "hud",
            "type": "command",
            "command": "'bun' \"$GEMINI_PROJECT_DIR/.gemini/hooks/hud.ts\"",
            "timeout": 3000
          }
        ],
        "matcher": "*"
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "oma-hook-AfterAgent",
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR/.gemini/hooks/oma-hook.sh\" --vendor 'gemini' --event 'AfterAgent' --matcher '*'",
            "timeout": 5005
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "hud",
            "type": "command",
            "command": "'bun' \"$GEMINI_PROJECT_DIR/.gemini/hooks/hud.ts\"",
            "timeout": 3000
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "general": {
    "enableNotifications": true
  },
  "experimental": {
    "enableAgents": true
  },
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--isolated"
      ]
    },
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        ".",
        "--open-web-dashboard",
        "false"
      ],
      "env": {
        "SERENA_LOG_LEVEL": "info"
      }
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  }
}
