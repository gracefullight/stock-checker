{
  "hooks": {
    "PreInvocation": [
      {
        "hooks": [
          {
            "name": "oma-hook-PreInvocation",
            "type": "command",
            "command": "'.gemini/antigravity-cli/hooks/oma-hook.sh' --vendor 'antigravity' --event 'PreInvocation'",
            "timeout": 21
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "name": "oma-hook-PreToolUse",
            "type": "command",
            "command": "'.gemini/antigravity-cli/hooks/oma-hook.sh' --vendor 'antigravity' --event 'PreToolUse' --matcher 'run_command'",
            "timeout": 10
          }
        ],
        "matcher": "run_command"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "oma-hook-Stop",
            "type": "command",
            "command": "'.gemini/antigravity-cli/hooks/oma-hook.sh' --vendor 'antigravity' --event 'Stop'",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "'bun' '.gemini/antigravity-cli/hooks/hud.ts'"
  },
  "homeOnly": true
}
